<?xml version="1.0" encoding="utf-8"?>
<mujoco model="Indy7_boltnut_m20">

  <!-- ========================================================= -->
  <!-- Custom parameterized M20 bolt / nut SDF plugins             -->
  <!-- Requires your rebuilt libsdf_plugin.so with the new keys.    -->
  <!-- ========================================================= -->
  <extension>

    <!-- M20 bolt -->
    <plugin plugin="mujoco.sdf.bolt">
      <instance name="bolt">
        <config key="major_radius" value="0.0098"/>
        <config key="minor_radius" value="0.0083"/>
        <config key="pitch" value="0.0025"/>
        <config key="length" value="0.05"/>
        <config key="head_radius" value="0.015"/>
        <config key="head_height" value="0.012"/>
        <config key="phase" value="0"/>
      </instance>
    </plugin>

    <!-- M20 nut -->
    <plugin plugin="mujoco.sdf.nut">
      <instance name="nut">
        <config key="inner_major_radius" value="0.0103"/>
        <config key="inner_minor_radius" value="0.0090"/>
        <config key="pitch" value="0.0025"/>
        <config key="height" value="0.018"/>
        <config key="outer_radius" value="0.015"/>
        <config key="phase" value="0"/>
      </instance>
    </plugin>

  </extension>

  <compiler angle="radian" inertiafromgeom="false" coordinate="local" eulerseq="xyz"/>
  <size njmax="500" nconmax="300"/>

  <option 
      timestep="0.001" 
      gravity="0 0 -9.81" 
      noslip_iterations="200" 
      iterations="300" 
      integrator="RK4" 
      cone="pyramidal"
      sdf_iterations="10"
      sdf_initpoints="20"
  />

  <visual>
    <map force="0.1" zfar="30"/>
    <headlight diffuse="0.5 0.5 0.5" ambient="0.5 0.45 0.4" specular="1 1 1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <quality shadowsize="8192"/>
    <global offwidth="400" offheight="400"/>
    <scale framelength="0.1" framewidth="0.01" com="0.01"/>
  </visual>

  <default>
    <geom 
        contype="1" 
        conaffinity="1" 
        condim="6" 
        margin="0.00005" 
        solref=".02 1" 
        solimp=".95 .95 .001" 
        friction="0.3"
    />
    <joint armature="0.04" damping="1" limited="true"/>
  </default>

  <asset>
    <!-- Robot meshes -->
    <mesh name="Indy7_0" file="robot_mesh/Indy7_0.stl"/>
    <mesh name="Indy7_1" file="robot_mesh/Indy7_1.stl"/>
    <mesh name="Indy7_2" file="robot_mesh/Indy7_2.stl"/>
    <mesh name="Indy7_3" file="robot_mesh/Indy7_3.stl"/>
    <mesh name="Indy7_4" file="robot_mesh/Indy7_4.stl"/>
    <mesh name="Indy7_5" file="robot_mesh/Indy7_5.stl"/>
    <mesh name="Indy7_6" file="robot_mesh/Indy7_6.stl"/>
    <mesh name="indy_coupling_ft_sensor" file="robot_mesh/indy_coupling_ft_sensor.stl"/>
    <mesh name="indy_gripper_body" file="robot_mesh/indy_gripper_body.stl"/>
    <mesh name="indy7_gripper_finger1" file="robot_mesh/gripper_finger_v2.stl"/>
    <mesh name="indy7_gripper_finger2" file="robot_mesh/gripper_finger_v2_mirror.stl"/>

    <!-- Direct nutbolt.xml-style plugin meshes -->
    <mesh name="nut_mesh">
      <plugin instance="nut"/>
    </mesh>

    <mesh name="bolt">
      <plugin instance="bolt"/>
    </mesh>

    <!-- Textures and materials -->
    <texture 
        type="skybox" 
        builtin="gradient" 
        rgb1="0.53 0.81 0.92" 
        rgb2="1 1 1" 
        width="512" 
        height="512"
    />

    <texture 
        name="texplane" 
        type="2d" 
        builtin="checker" 
        rgb1=".05 .05 .05" 
        rgb2=".05 .05 .05" 
        width="512" 
        height="512" 
        mark="cross" 
        markrgb=".1 .1 .1"
    />

    <material 
        name="matplane" 
        reflectance="0.25" 
        texture="texplane" 
        texrepeat="1 1" 
        texuniform="true"
    />

    <texture 
        type="2d" 
        name="groundplane" 
        builtin="checker" 
        mark="edge" 
        rgb1="0.2 0.3 0.4"
        rgb2="0.1 0.2 0.3" 
        markrgb="0.8 0.8 0.8" 
        width="300" 
        height="300"
    />

    <material 
        name="groundplane" 
        texture="groundplane" 
        texuniform="true" 
        texrepeat="2 2"
        reflectance="0.15"
    />
  </asset>

  <worldbody>
    <geom 
        name="floor" 
        pos="0 0 0.0" 
        size="0 0 1" 
        type="plane" 
        material="groundplane" 
        condim="6" 
        contype="1"
    />

    <light 
        directional="true" 
        diffuse=".8 .8 .8" 
        specular=".2 .2 .2" 
        pos="0 0 5" 
        dir="1.5 1.0 -2"
    />

    <camera 
        name="overview" 
        pos="1.0 -1.2 0.8" 
        xyaxes="0.75 0.66 0 -0.35 0.40 0.85" 
        fovy="45"
    />

    <!-- ========================================================= -->
    <!-- Indy7 robot                                               -->
    <!-- ========================================================= -->
    <body name="indy_link0" pos="0 0 0" euler="0 0 0">
      <inertial 
          pos="0.001045240000000 -0.000003790000000 -0.015046150000000" 
          mass="1.59306955" 
          fullinertia="+0.00572623 +0.00558959 +0.00966674 +0.00000251 -0.00011380 -0.00000014"
      />

      <geom 
          type="mesh" 
          mesh="Indy7_0" 
          contype="0" 
          conaffinity="0" 
          group="0" 
          rgba="0.584 0.584 0.584 1"
      />

      <body name="indy_link1" pos="0 0 0.0775" euler="0 0 0">
        <inertial 
            pos="0 -0.0473238 0.193496" 
            quat="0.646983 -0.156312 0.175179 0.72546" 
            mass="11.803" 
            diaginertia="0.154273 0.154184 0.0347425"
        />

        <joint 
            name="indy_joint1" 
            range="-3.05432619099 3.05432619099" 
            armature="4" 
            damping="100"
            frictionloss="0"
        />

        <geom 
            type="mesh" 
            mesh="Indy7_1" 
            rgba="0.737 0.737 0.768 1"
        />

        <body name="indy_link2" pos="0 -0.109 0.222" quat="0.5 0.5 0.5 -0.5">
          <inertial 
              pos="-0.252661 6.01e-06 0.0594623" 
              quat="0.535651 0.461652 0.461734 0.535497" 
              mass="7.99292" 
              diaginertia="0.29363 0.286497 0.0306505"
          />

          <joint 
              name="indy_joint2" 
              range="-3.05432619099 3.05432619099" 
              armature="4" 
              damping="100"
              frictionloss="0"
          />

          <geom 
              type="mesh" 
              mesh="Indy7_2" 
              rgba="0.737 0.737 0.768 1"
          />

          <body name="indy_link3" pos="-0.45 0 -0.0305" euler="0 0 0">
            <inertial 
                pos="-0.151721 4.441e-05 -0.073199" 
                quat="0.490517 0.508363 -0.522312 -0.477652" 
                mass="2.99134" 
                diaginertia="0.0342713 0.0342015 0.0043907"
            />

            <joint 
                name="indy_joint3" 
                range="-3.05432619099 3.05432619099" 
                armature="1" 
                damping="50"
                frictionloss="0"
            />

            <geom 
                type="mesh" 
                mesh="Indy7_3" 
                rgba="0.737 0.737 0.768 1"
            />

            <body name="indy_link4" pos="-0.267 0 -0.075" quat="0.5 -0.5 -0.5 0.5">
              <inertial 
                  pos="6.946e-05 -0.0722404 0.0745651" 
                  quat="0.584096 0.811684 -0.000311929 0.00081235" 
                  mass="2.12317" 
                  diaginertia="0.00672334 0.00662338 0.00236249"
              />

              <joint 
                  name="indy_joint4" 
                  range="-6.28318530718 6.28318530718"
                  armature="1" 
                  damping="25"
                  frictionloss="0"
              />

              <geom 
                  type="mesh" 
                  mesh="Indy7_4" 
                  rgba="0.737 0.737 0.768 1"
              />

              <body name="indy_link5" pos="0 -0.114 0.083" quat="0.5 0.5 0.5 -0.5">
                <inertial 
                    pos="-0.0928619 6.474e-05 0.0657795" 
                    quat="0.464788 0.53361 0.528902 0.468503" 
                    mass="2.28865" 
                    diaginertia="0.00996598 0.00992026 0.00259951"
                />

                <joint 
                    name="indy_joint5" 
                    range="-6.28318530718 6.28318530718"
                    armature="0.8" 
                    damping="25"
                    frictionloss="0.0"
                />

                <geom 
                    type="mesh" 
                    mesh="Indy7_5" 
                    rgba="0.737 0.737 0.768 1"
                />

                <body name="indy_link6" pos="-0.168 0 0.069" quat="0.5 -0.5 -0.5 0.5">
                  <inertial 
                      pos="0 -0.00048743 0.0306234" 
                      quat="0.00572522 0.707041 -0.00333531 0.707142" 
                      mass="0.400839" 
                      diaginertia="0.000596342 0.00044549 0.000435338"
                  />

                  <joint 
                      name="indy_joint6" 
                      range="-16.5663706144 16.5663706144"
                      armature="0.8" 
                      damping="15"
                      frictionloss="0.0"
                  />

                  <geom 
                      type="mesh" 
                      mesh="Indy7_6" 
                      rgba="0.737 0.737 0.768 1"
                  />

                  <body name="last_link" pos="0.0 0 0.06" euler="0 0 0">
                    <inertial 
                        pos="0 -0.00048743 0.0306234" 
                        quat="0.00572522 0.707041 -0.00333531 0.707142" 
                        mass="1e-9" 
                        diaginertia="0.0 0.0 0.0"
                    />

                    <site 
                        name="ft_sensor" 
                        type="cylinder" 
                        size="0.045 0.01" 
                        pos="0.0 0 0.01" 
                        euler="0 0 0" 
                        rgba="1 0 0 0.00"
                    />
                  </body>

                  <body name="ft_assembly" pos="0.0 0.0 0.06">
                    <geom 
                        type="mesh" 
                        mesh="indy_coupling_ft_sensor" 
                        rgba="0.584 0.584 0.584 1"
                    />

                    <body name="gripper_body" pos="0.0 0.0 0.067">
                      <geom 
                          type="mesh" 
                          mesh="indy_gripper_body" 
                          friction="0.3" 
                          contype="1" 
                          conaffinity="1" 
                          condim="6" 
                          solimp="0.99 0.99 0.001" 
                          solref="0.001 1" 
                          margin="0.002"
                      />

                      <body name="gripper_finger1" pos="-0.020 -0.0075 0.061">
                        <inertial 
                            pos="0 0 0" 
                            euler="0 0 0" 
                            mass="0.01" 
                            diaginertia="0.001 0.001 0.001"
                        />

                        <geom 
                            type="mesh" 
                            mesh="indy7_gripper_finger1" 
                            friction="0.3" 
                            contype="1" 
                            conaffinity="1" 
                            condim="6" 
                            solimp="0.99 0.99 0.001" 
                            solref="0.001 1" 
                            margin="0.002" 
                            rgba="0.129 0.129 0.129 1"
                        />

                        <joint 
                            axis="1 0 0" 
                            pos="0 0 0" 
                            name="jointf1" 
                            damping="3" 
                            range="-0.03 0.0" 
                            type="slide"
                        />
                      </body>

                      <body name="gripper_finger2" pos="0.020 0.0075 0.061">
                        <inertial 
                            pos="0 0 0" 
                            euler="0 0 0" 
                            mass="0.01" 
                            diaginertia="0.001 0.001 0.001"
                        />

                        <geom 
                            type="mesh" 
                            mesh="indy7_gripper_finger2" 
                            friction="0.3" 
                            contype="1" 
                            conaffinity="1" 
                            condim="6" 
                            solimp="0.99 0.99 0.001" 
                            solref="0.001 1" 
                            margin="0.002" 
                            rgba="0.129 0.129 0.129 1"
                        />

                        <joint 
                            axis="1 0 0" 
                            pos="0 0 0" 
                            name="jointf2" 
                            damping="3" 
                            range="0.0 0.03" 
                            type="slide"
                        />
                      </body>
                    </body>

                    <body name="eye_in_hand_body" pos="0.00 -0.08 0.05" euler="3.1415 0 0">
                      <geom 
                          name="eye_in_hand_marker"
                          type="box"
                          size="0.015 0.01 0.01"
                          rgba="1 0 0 0.5"
                          contype="0"
                          conaffinity="0"
                      />

                      <camera 
                          name="eye_in_hand"
                          mode="fixed"
                          pos="0 0 0"
                          euler="0 0 0"
                          fovy="70"
                      />
                    </body>

                    <!-- ================================================= -->
                    <!-- M20 bolt tool: replaces original peg                 -->
                    <!-- The bolt head is close to the gripper; shaft points outward. -->
                    <!-- ================================================= -->
                    <body name="bolt_tool" pos="0.0 0.0 0.0">
                      <inertial 
                          pos="0 0 0.160" 
                          euler="0 0 0" 
                          mass="0.08" 
                          diaginertia="0.0008 0.0008 0.0008"
                      />

                      <geom 
                          name="bolt_geom" 
                          type="sdf" 
                          mesh="bolt"
                          pos="0.0 0.0 0.21"
                          euler="3.1415926 0 0"
                          friction="0.15 0.005 0.0001"
                        >
                        <plugin instance="bolt"/>
                      </geom>

                      <!-- This site is placed at the approximate screw tip. -->
                      <site 
                          name="end_effector" 
                          type="sphere" 
                          size="0.005" 
                          pos="0.0 0 0.210" 
                          euler="0 0 0" 
                          rgba="1 0 0 1.00"
                      />
                      <site 
                            name="bolt_axis_base"
                            type="sphere"
                            size="0.004"
                            pos="0 0 0.160"
                            rgba="1 0 0 1"
                        />

                        <site 
                            name="bolt_axis_tip"
                            type="sphere"
                            size="0.004"
                            pos="0 0 0.210"
                            rgba="0 1 0 1"
                        />
                    </body>

                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- ========================================================= -->
    <!-- M20 nut target: replaces original hole                    -->
    <!-- Nut is fixed on a support block.                          -->
    <!-- ========================================================= -->
    <body name="nut_target" pos="0.5 0 0.11">
      <geom 
          name="nut_base_geom" 
          type="box" 
          size="0.060 0.060 0.012" 
          pos="0 0 0" 
          rgba="0.1 0.1 0.8 1" 
          friction="0.5"
          contype="1" 
          conaffinity="1" 
          condim="6" 
          solimp="0.99 0.99 0.001" 
          solref="0.001 1" 
          margin="0.0001"
      />
      <geom 
          name="nut_geom" 
          type="sdf" 
          mesh="nut_mesh"
          pos="0 0 0.032"
          friction="0.15 0.005 0.0001"
          >
        <plugin instance="nut"/>
      </geom>
    </body>

  </worldbody>

  <actuator>
    <motor 
        name="indy_joint0_actuator" 
        joint="indy_joint1" 
        gear="1 0 0 0 0 0" 
        ctrllimited="false" 
        ctrlrange="-1e6 1e6" 
        forcerange="-1e6 1e6"
    />

    <motor 
        name="indy_joint1_actuator" 
        joint="indy_joint2" 
        gear="1 0 0 0 0 0" 
        ctrllimited="false" 
        ctrlrange="-1e6 1e6" 
        forcerange="-1e6 1e6"
    />

    <motor 
        name="indy_joint2_actuator" 
        joint="indy_joint3" 
        gear="1 0 0 0 0 0" 
        ctrllimited="false" 
        ctrlrange="-1e6 1e6" 
        forcerange="-1e6 1e6"
    />

    <motor 
        name="indy_joint3_actuator" 
        joint="indy_joint4" 
        gear="1 0 0 0 0 0" 
        ctrllimited="false" 
        ctrlrange="-1e6 1e6" 
        forcerange="-1e6 1e6"
    />

    <motor 
        name="indy_joint4_actuator" 
        joint="indy_joint5" 
        gear="1 0 0 0 0 0" 
        ctrllimited="false" 
        ctrlrange="-1e6 1e6" 
        forcerange="-1e6 1e6"
    />

    <motor 
        name="indy_joint5_actuator" 
        joint="indy_joint6" 
        gear="1 0 0 0 0 0" 
        ctrllimited="false" 
        ctrlrange="-1e6 1e6" 
        forcerange="-1e6 1e6"
    />

    <position 
        ctrllimited="true" 
        ctrlrange="-0.03 0" 
        joint="jointf1" 
        kp="2000" 
        name="actf1"
    />

    <position 
        ctrllimited="true" 
        ctrlrange="0.0 0.03" 
        joint="jointf2" 
        kp="2000" 
        name="actf2"
    />
  </actuator>

  <sensor>
    <framepos objtype="site" objname="end_effector"/>
    <force name="force_sensor" site="end_effector"/>
    <torque name="torque_sensor" site="end_effector"/>
  </sensor>
    
</mujoco>